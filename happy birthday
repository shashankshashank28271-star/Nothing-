<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Happy 18th Birthday Chandrika Sindhya! 🎂✨</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Dancing+Script:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            margin: 0;
            overflow: hidden;
            font-family: 'Poppins', 'Quicksand', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
            cursor: grab;
        }

        body:active {
            cursor: grabbing;
        }

        /* UI Overlay */
        .ui-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 10;
        }

        /* Birthday Card */
        .birthday-card {
            position: absolute;
            bottom: 20px;
            left: 20px;
            max-width: 300px;
            background: linear-gradient(135deg, rgba(255,245,235,0.95), rgba(255,235,215,0.95));
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            border-left: 8px solid #ff6b6b;
            animation: slideInLeft 0.6s ease-out;
            pointer-events: auto;
        }

        @keyframes slideInLeft {
            from {
                transform: translateX(-100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .birthday-card h1 {
            font-family: 'Dancing Script', cursive;
            font-size: 2.2rem;
            margin: 0 0 5px 0;
            color: #ff6b6b;
            text-shadow: 2px 2px 0 #ffe0b5;
        }

        .birthday-card .date {
            color: #ff8c69;
            font-weight: bold;
            font-size: 1.1rem;
            margin: 5px 0;
        }

        .birthday-card p {
            color: #5a3e2e;
            margin: 10px 0;
            font-size: 0.95rem;
            line-height: 1.4;
        }

        .photo-preview {
            margin-top: 10px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        /* Cake Game Panel */
        .cake-game-panel {
            position: absolute;
            bottom: 20px;
            right: 20px;
            width: 280px;
            background: linear-gradient(135deg, rgba(255,245,230,0.96), rgba(255,235,215,0.96));
            backdrop-filter: blur(8px);
            border-radius: 30px;
            padding: 15px 20px;
            text-align: center;
            cursor: pointer;
            pointer-events: auto;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            animation: slideInRight 0.6s ease-out;
            transition: transform 0.3s;
        }

        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .cake-game-panel:hover {
            transform: scale(1.02);
        }

        .cake-game-panel h3 {
            margin: 0 0 10px 0;
            color: #ff6b6b;
            font-weight: bold;
            font-size: 1.3rem;
        }

        .cake-progress {
            background: #ffd7b0;
            border-radius: 40px;
            height: 20px;
            width: 100%;
            overflow: hidden;
            margin: 12px 0;
            cursor: pointer;
        }

        .cake-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #ff8866, #ff6b6b);
            border-radius: 40px;
            transition: width 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .cake-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: shine 1.5s infinite;
        }

        @keyframes shine {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .drag-hint {
            font-size: 0.8rem;
            color: #ff8866;
            margin-top: 8px;
            font-weight: 500;
        }

        #cakeCutStatus {
            font-size: 0.9rem;
            font-weight: bold;
            color: #ff6b6b;
            margin-top: 8px;
        }

        /* Buttons */
        .action-btn {
            background: linear-gradient(135deg, #ff8866, #ff6b6b);
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            color: white;
            font-weight: bold;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Poppins', sans-serif;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            pointer-events: auto;
        }

        .action-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.3);
        }

        .confess-btn {
            position: absolute;
            bottom: 130px;
            left: 20px;
            background: linear-gradient(135deg, #ff99cc, #ff6b9d);
            z-index: 20;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .game-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: linear-gradient(135deg, #ffd966, #ffb347);
            z-index: 20;
        }

        .upload-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: linear-gradient(135deg, #a8e6cf, #6c9ebf);
            font-size: 0.85rem;
            padding: 8px 15px;
        }

        .music-btn {
            position: absolute;
            top: 90px;
            left: 20px;
            background: linear-gradient(135deg, #ffb7b2, #ff6b6b);
            font-size: 0.85rem;
            padding: 8px 15px;
        }

        /* Modals */
        .modal {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            max-width: 600px;
            width: 90%;
            background: linear-gradient(135deg, #fff9f0, #fff0e0);
            border-radius: 40px;
            padding: 30px;
            text-align: center;
            box-shadow: 0 30px 50px rgba(0,0,0,0.4);
            border: 2px solid #ffb48a;
            transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            pointer-events: auto;
            z-index: 200;
            animation: modalPop 0.5s ease-out;
        }

        @keyframes modalPop {
            from {
                transform: translate(-50%, -50%) scale(0.8);
                opacity: 0;
            }
            to {
                transform: translate(-50%, -50%) scale(1);
                opacity: 1;
            }
        }

        .modal h2 {
            font-family: 'Dancing Script', cursive;
            font-size: 2rem;
            color: #ff6b6b;
            margin-bottom: 20px;
        }

        .modal p {
            color: #4a2a2a;
            font-size: 1.1rem;
            line-height: 1.6;
            font-weight: 500;
            max-height: 60vh;
            overflow-y: auto;
            padding: 10px;
        }

        .modal button {
            background: linear-gradient(135deg, #ff8866, #ff6b6b);
            border: none;
            padding: 12px 30px;
            border-radius: 50px;
            color: white;
            font-weight: bold;
            font-size: 1rem;
            margin-top: 20px;
            cursor: pointer;
            transition: 0.3s;
        }

        .modal button:hover {
            transform: scale(1.05);
        }

        .hidden {
            display: none;
        }

        /* Game Overlay */
        .game-overlay {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 500px;
            height: 500px;
            background: linear-gradient(135deg, rgba(30,20,50,0.98), rgba(20,15,40,0.98));
            backdrop-filter: blur(15px);
            border-radius: 50px;
            z-index: 500;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border: 3px solid gold;
            box-shadow: 0 0 50px rgba(255,215,0,0.3);
            animation: gamePop 0.4s ease-out;
        }

        @keyframes gamePop {
            from {
                transform: translate(-50%, -50%) scale(0.7);
                opacity: 0;
            }
            to {
                transform: translate(-50%, -50%) scale(1);
                opacity: 1;
            }
        }

        .game-overlay h2 {
            color: #ffdd99;
            margin-bottom: 20px;
        }

        .star-target {
            width: 80px;
            height: 80px;
            background: radial-gradient(circle, #ffd700, #ffb347);
            border-radius: 50%;
            margin: 20px;
            cursor: pointer;
            transition: all 0.1s;
            box-shadow: 0 0 20px rgba(255,215,0,0.8);
            animation: starGlow 1s infinite;
        }

        @keyframes starGlow {
            0%, 100% { transform: scale(1); box-shadow: 0 0 20px gold; }
            50% { transform: scale(1.1); box-shadow: 0 0 40px #ffaa00; }
        }

        .star-target:hover {
            transform: scale(1.1);
        }

        #starScore {
            font-size: 3rem;
            font-weight: bold;
            color: #ffdd99;
            margin: 20px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .birthday-card { max-width: 260px; padding: 15px; }
            .birthday-card h1 { font-size: 1.6rem; }
            .cake-game-panel { width: 250px; padding: 12px 15px; }
            .game-overlay { width: 90%; height: auto; min-height: 400px; }
            .modal p { font-size: 0.95rem; }
        }

        /* Instructions */
        .instruction {
            position: absolute;
            bottom: 100px;
            left: 20px;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 0.7rem;
            color: #ffdd99;
            pointer-events: none;
            z-index: 5;
        }
    </style>
</head>
<body>
    <div class="ui-container">
        <!-- Birthday Card -->
        <div class="birthday-card">
            <h1>🎂 Happy 18th Birthday! 🎂</h1>
            <div class="date">✨ 5th April ✨</div>
            <p>To my dearest <strong>Chandrika Sindhya</strong><br>
            Turning 18 with grace and charm!<br>
            May your day be filled with magic and joy! 💖</p>
            <div class="photo-preview" id="photoPreview"></div>
        </div>

        <!-- Cake Cutting Panel -->
        <div class="cake-game-panel">
            <h3>🍰 Magic Celebration Cake 🍰</h3>
            <div class="cake-progress">
                <div class="cake-fill" id="cakeFill"></div>
            </div>
            <div class="drag-hint">💫 Drag the knife across the cake to cut! 💫</div>
            <div id="cakeCutStatus">0% cut</div>
        </div>

        <!-- Action Buttons -->
        <button class="action-btn confess-btn" id="confessBtn">💌 Read My Heart 💌</button>
        <button class="action-btn game-btn" id="crazyGameBtn">🎈 Play Star Catcher 🎈</button>
        <button class="action-btn upload-btn" id="uploadPhotoBtn">📸 Add Your Photo</button>
        <button class="action-btn music-btn" id="uploadMusicBtn">🎵 Add Background Music</button>
        
        <div class="instruction">✨ 3D Character | Drag knife on cake | Click heart for special message ✨</div>
    </div>

    <!-- Modals -->
    <div id="confessionModal" class="modal hidden">
        <h2>💌 A Message From My Heart 💌</h2>
        <p id="confessionText"></p>
        <button id="revealFinalBtn">Continue →</button>
    </div>

    <div id="finalThanksModal" class="modal hidden">
        <h2>🌸 Thank You 🌸</h2>
        <p>Thank you for reading what's in my heart. I request you to keep this between us, and let's keep our beautiful friendship forever. 💖</p>
        <button id="closeFinalBtn">✨ Keep Our Friendship Magical ✨</button>
    </div>

    <audio id="bgMusic" loop style="display:none;"></audio>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'https://unpkg.com/three@0.128.0/examples/jsm/controls/OrbitControls.js';

        // ========== 3D SCENE SETUP ==========
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x0a0a2a);
        scene.fog = new THREE.FogExp2(0x0a0a2a, 0.008);
        
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(2.5, 2, 4.5);
        camera.lookAt(0, 1.2, 0);
        
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.shadowMap.enabled = true;
        renderer.setPixelRatio(window.devicePixelRatio);
        document.body.appendChild(renderer.domElement);
        
        // Controls
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.enableZoom = true;
        controls.zoomSpeed = 1.0;
        controls.rotateSpeed = 1.0;
        controls.target.set(0, 1.2, 0);
        
        // Lighting
        const ambientLight = new THREE.AmbientLight(0x404060);
        scene.add(ambientLight);
        
        const mainLight = new THREE.DirectionalLight(0xffccaa, 1.2);
        mainLight.position.set(3, 5, 2);
        mainLight.castShadow = true;
        mainLight.receiveShadow = true;
        scene.add(mainLight);
        
        const fillLight = new THREE.PointLight(0xffaa88, 0.5);
        fillLight.position.set(1, 2, 2);
        scene.add(fillLight);
        
        const backLight = new THREE.PointLight(0x99aaff, 0.4);
        backLight.position.set(-1, 1.5, -2);
        scene.add(backLight);
        
        const rimLight = new THREE.PointLight(0xffddbb, 0.6);
        rimLight.position.set(1, 2, -1.5);
        scene.add(rimLight);
        
        const coloredLight = new THREE.PointLight(0xff66aa, 0.4);
        coloredLight.position.set(-1, 1.8, 1.5);
        scene.add(coloredLight);
        
        // Ground
        const groundDisc = new THREE.Mesh(
            new THREE.CircleGeometry(4, 32),
            new THREE.MeshStandardMaterial({ color: 0x2a2352, roughness: 0.7, metalness: 0.1, transparent: true, opacity: 0.5 })
        );
        groundDisc.rotation.x = -Math.PI / 2;
        groundDisc.position.y = -0.8;
        groundDisc.receiveShadow = true;
        scene.add(groundDisc);
        
        // Create Cute 3D Character
        const characterGroup = new THREE.Group();
        
        // Body
        const bodyMat = new THREE.MeshStandardMaterial({ color: 0xffccaa, roughness: 0.3, emissive: 0x442200, emissiveIntensity: 0.1 });
        const torso = new THREE.Mesh(new THREE.CylinderGeometry(0.48, 0.52, 0.95, 32), bodyMat);
        torso.position.y = 0.45;
        torso.castShadow = true;
        characterGroup.add(torso);
        
        // Head
        const headMat = new THREE.MeshStandardMaterial({ color: 0xffddbb, roughness: 0.2 });
        const head = new THREE.Mesh(new THREE.SphereGeometry(0.52, 64, 64), headMat);
        head.position.y = 1.05;
        head.castShadow = true;
        characterGroup.add(head);
        
        // Eyes
        const eyeWhite = new THREE.MeshStandardMaterial({ color: 0xffffff });
        const leftEye = new THREE.Mesh(new THREE.SphereGeometry(0.12, 32, 32), eyeWhite);
        leftEye.position.set(-0.18, 1.22, 0.55);
        const rightEye = new THREE.Mesh(new THREE.SphereGeometry(0.12, 32, 32), eyeWhite);
        rightEye.position.set(0.18, 1.22, 0.55);
        characterGroup.add(leftEye, rightEye);
        
        // Pupils
        const pupilMat = new THREE.MeshStandardMaterial({ color: 0x2a1a0a });
        const leftPupil = new THREE.Mesh(new THREE.SphereGeometry(0.07, 32, 32), pupilMat);
        leftPupil.position.set(-0.18, 1.20, 0.72);
        const rightPupil = new THREE.Mesh(new THREE.SphereGeometry(0.07, 32, 32), pupilMat);
        rightPupil.position.set(0.18, 1.20, 0.72);
        characterGroup.add(leftPupil, rightPupil);
        
        // Blush
        const blushMat = new THREE.MeshStandardMaterial({ color: 0xffaaaa });
        const leftBlush = new THREE.Mesh(new THREE.SphereGeometry(0.08, 24, 24), blushMat);
        leftBlush.position.set(-0.35, 0.98, 0.58);
        const rightBlush = new THREE.Mesh(new THREE.SphereGeometry(0.08, 24, 24), blushMat);
        rightBlush.position.set(0.35, 0.98, 0.58);
        characterGroup.add(leftBlush, rightBlush);
        
        // Hair
        const hairMat = new THREE.MeshStandardMaterial({ color: 0x8b5a2b });
        const hair = new THREE.Mesh(new THREE.SphereGeometry(0.56, 32, 32), hairMat);
        hair.position.y = 1.33;
        hair.scale.set(1.0, 0.5, 1.1);
        characterGroup.add(hair);
        
        // Party Hat
        const hatMat = new THREE.MeshStandardMaterial({ color: 0xff6b6b });
        const hat = new THREE.Mesh(new THREE.ConeGeometry(0.4, 0.75, 16), hatMat);
        hat.position.y = 1.68;
        hat.castShadow = true;
        characterGroup.add(hat);
        
        const hatBall = new THREE.Mesh(new THREE.SphereGeometry(0.1, 16, 16), new THREE.MeshStandardMaterial({ color: 0xffdd99 }));
        hatBall.position.y = 2.02;
        characterGroup.add(hatBall);
        
        // Smile (small curve)
        const smilePoints = [];
        for (let i = -0.25; i <= 0.25; i += 0.05) {
            smilePoints.push(new THREE.Vector3(i, 0.85, 0.65));
        }
        const smileLine = new THREE.Line(
            new THREE.BufferGeometry().setFromPoints(smilePoints),
            new THREE.LineBasicMaterial({ color: 0xcc8866 })
        );
        characterGroup.add(smileLine);
        
        scene.add(characterGroup);
        
        // Floating Hearts
        const hearts = [];
        for (let i = 0; i < 40; i++) {
            const heart = new THREE.Mesh(
                new THREE.SphereGeometry(0.04, 8, 8),
                new THREE.MeshStandardMaterial({ color: 0xff6b6b, emissive: 0x441111 })
            );
            heart.userData = { speed: 0.002 + Math.random() * 0.005, offset: Math.random() * Math.PI * 2, x: (Math.random() - 0.5) * 4, z: (Math.random() - 0.5) * 4 };
            heart.position.set(heart.userData.x, Math.random() * 2.5, heart.userData.z);
            scene.add(heart);
            hearts.push(heart);
        }
        
        // Cake
        const cakeGroup = new THREE.Group();
        const cakeBase = new THREE.Mesh(new THREE.CylinderGeometry(0.75, 0.8, 0.28, 32), new THREE.MeshStandardMaterial({ color: 0xf5bc70 }));
        cakeBase.position.y = -0.58;
        cakeBase.castShadow = true;
        cakeGroup.add(cakeBase);
        
        const cakeMiddle = new THREE.Mesh(new THREE.CylinderGeometry(0.65, 0.72, 0.24, 32), new THREE.MeshStandardMaterial({ color: 0xffd58c }));
        cakeMiddle.position.y = -0.34;
        cakeMiddle.castShadow = true;
        cakeGroup.add(cakeMiddle);
        
        const frosting = new THREE.Mesh(new THREE.TorusGeometry(0.72, 0.06, 16, 64), new THREE.MeshStandardMaterial({ color: 0xffc2a1 }));
        frosting.position.y = -0.21;
        cakeGroup.add(frosting);
        
        const candle = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.09, 0.45, 12), new THREE.MeshStandardMaterial({ color: 0xffaaaa }));
        candle.position.set(0.1, -0.08, 0.1);
        candle.castShadow = true;
        cakeGroup.add(candle);
        
        const flame = new THREE.Mesh(new THREE.ConeGeometry(0.07, 0.14, 8), new THREE.MeshStandardMaterial({ color: 0xff6600, emissive: 0xff3300 }));
        flame.position.set(0.1, 0.14, 0.1);
        cakeGroup.add(flame);
        
        cakeGroup.position.set(1.3, -0.35, -1.3);
        scene.add(cakeGroup);
        
        // Knife
        const knifeGroup = new THREE.Group();
        const blade = new THREE.Mesh(new THREE.BoxGeometry(0.45, 0.03, 0.09), new THREE.MeshStandardMaterial({ color: 0xccccdd, metalness: 0.7 }));
        blade.position.set(0.22, 0, 0);
        const handle = new THREE.Mesh(new THREE.BoxGeometry(0.14, 0.05, 0.12), new THREE.MeshStandardMaterial({ color: 0xaa8866 }));
        handle.position.set(-0.08, 0, 0);
        knifeGroup.add(blade, handle);
        knifeGroup.position.set(1.7, 0.05, -1.1);
        knifeGroup.scale.set(0.8, 0.8, 0.8);
        scene.add(knifeGroup);
        
        // Sparkles
        const sparkleCount = 600;
        const sparkleGeo = new THREE.BufferGeometry();
        const sparklePos = [];
        for (let i = 0; i < sparkleCount; i++) {
            sparklePos.push((Math.random() - 0.5) * 12);
            sparklePos.push(Math.random() * 3.5);
            sparklePos.push((Math.random() - 0.5) * 10);
        }
        sparkleGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(sparklePos), 3));
        const sparkles = new THREE.Points(sparkleGeo, new THREE.PointsMaterial({ color: 0xffaa77, size: 0.02, transparent: true, blending: THREE.AdditiveBlending }));
        scene.add(sparkles);
        
        // Cake Cutting Logic
        let cutAmount = 0;
        const cakeFillDiv = document.getElementById('cakeFill');
        const cutStatusSpan = document.getElementById('cakeCutStatus');
        let isDragging = false;
        const raycaster = new THREE.Raycaster();
        const dragPlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0.1);
        
        function updateCakeCut() {
            cakeFillDiv.style.width = (cutAmount * 100) + '%';
            cutStatusSpan.innerHTML = Math.floor(cutAmount * 100) + '% cut';
            if (cutAmount >= 0.99 && cutAmount < 1) {
                cutAmount = 1;
                cutStatusSpan.innerHTML = '🎉 Cake Fully Cut! Celebration Time! 🎉';
                createConfetti();
                // Animate flame
                flame.scale.set(0, 0, 0);
            }
        }
        
        function createConfetti() {
            for (let i = 0; i < 150; i++) {
                const conf = document.createElement('div');
                conf.style.position = 'fixed';
                conf.style.width = (5 + Math.random() * 8) + 'px';
                conf.style.height = (8 + Math.random() * 12) + 'px';
                conf.style.backgroundColor = `hsl(${Math.random() * 360}, 80%, 60%)`;
                conf.style.left = Math.random() * window.innerWidth + 'px';
                conf.style.top = '-20px';
                conf.style.position = 'fixed';
                conf.style.zIndex = 1000;
                conf.style.pointerEvents = 'none';
                conf.style.borderRadius = '2px';
                conf.style.animation = `fall ${1 + Math.random() * 2}s linear forwards`;
                document.body.appendChild(conf);
                setTimeout(() => conf.remove(), 3000);
            }
            const style = document.createElement('style');
            style.textContent = `@keyframes fall { to { transform: translateY(${window.innerHeight + 50}px) rotate(360deg); opacity: 0; } }`;
            document.head.appendChild(style);
        }
        
        function onMouseMove(e) {
            if (!isDragging) return;
            const mouse = new THREE.Vector2();
            mouse.x = (e.clientX / renderer.domElement.clientWidth) * 2 - 1;
            mouse.y = -(e.clientY / renderer.domElement.clientHeight) * 2 + 1;
            raycaster.setFromCamera(mouse, camera);
            const intersect = raycaster.ray.intersectPlane(dragPlane, new THREE.Vector3());
            if (intersect) {
                knifeGroup.position.x = Math.min(1.95, Math.max(0.65, intersect.x));
                knifeGroup.position.z = Math.min(-0.6, Math.max(-1.85, intersect.z));
                if (knifeGroup.position.x > 0.9 && knifeGroup.position.x < 1.7 && knifeGroup.position.z > -1.75 && knifeGroup.position.z < -0.85) {
                    if (cutAmount < 1) {
                        cutAmount = Math.min(1, cutAmount + 0.012);
                        updateCakeCut();
                    }
                }
            }
        }
        
        renderer.domElement.addEventListener('mousedown', (e) => { isDragging = true; e.preventDefault(); });
        window.addEventListener('mousemove', onMouseMove);
        window.addEventListener('mouseup', () => { isDragging = false; });
        
        // Confession Logic
        const confessionMsg = `Hey miss Chandrika Sindhya, I don't know how to tell you that I have feelings for you. I don't know how but yeah, whenever I am with you, talk to you, and interacting with you, my heart feels amazing. And then I get why the reason was — I like you. I wanted to tell you that in the past but I couldn't, so now it's time to say: "I LIKE YOU". And if it feels bad, I am sorry for this and I request you to don't ruin our friendship. Our friendship was from childhood and that was the best. Once again I really love you Chandrika, whatever it is. 💗`;
        
        const confessModal = document.getElementById('confessionModal');
        const finalModal = document.getElementById('finalThanksModal');
        const confessBtn = document.getElementById('confessBtn');
        const confessionText = document.getElementById('confessionText');
        
        confessBtn.addEventListener('click', () => {
            confessionText.innerText = confessionMsg;
            confessModal.classList.remove('hidden');
        });
        
        document.getElementById('revealFinalBtn').addEventListener('click', () => {
            confessModal.classList.add('hidden');
            finalModal.classList.remove('hidden');
        });
        
        document.getElementById('closeFinalBtn').addEventListener('click', () => {
            finalModal.classList.add('hidden');
        });
        
        // Crazy Game
        let gameActive = false;
        document.getElementById('crazyGameBtn').addEventListener('click', () => {
            if (gameActive) return;
            startStarGame();
        });
        
        function startStarGame() {
            gameActive = true;
            const gameDiv = document.createElement('div');
            gameDiv.className = 'game-overlay';
            gameDiv.innerHTML = `
                <h2>✨ Catch the Sparkle Stars! ✨</h2>
                <div id="starScore" style="font-size: 3rem; font-weight: bold; color: #ffdd99;">0</div>
                <div class="star-target" id="starTarget"></div>
                <button class="action-btn" id="closeGameBtn" style="margin-top: 20px;">Close Game</button>
                <p style="margin-top: 15px; color: #ffdd99;">Click the moving star! Get 10 points!</p>
            `;
            document.body.appendChild(gameDiv);
            
            let score = 0;
            const scoreSpan = document.getElementById('starScore');
            const starDiv = document.getElementById('starTarget');
            
            function moveStar() {
                const maxX = gameDiv.clientWidth - 120;
                const maxY = gameDiv.clientHeight - 180;
                const randX = Math.max(20, Math.min(maxX, Math.random() * maxX));
                const randY = Math.max(50, Math.min(maxY, Math.random() * maxY));
                starDiv.style.position = 'absolute';
                starDiv.style.left = randX + 'px';
                starDiv.style.top = randY + 'px';
            }
            
            starDiv.addEventListener('click', () => {
                score++;
                scoreSpan.innerText = score;
                moveStar();
                if (score >= 10) {
                    gameDiv.innerHTML = `<h2>🎉 You're Amazing! 🎉</h2><p style="color: gold; font-size: 1.5rem;">You won the game! Just like you win hearts! 💖</p><button class="action-btn" id="closeGameBtn2">Close</button>`;
                    document.getElementById('closeGameBtn2').addEventListener('click', () => { gameDiv.remove(); gameActive = false; });
                    gameActive = false;
                    createConfetti();
                } else {
                    moveStar();
                }
            });
            
            document.getElementById('closeGameBtn').addEventListener('click', () => { gameDiv.remove(); gameActive = false; });
            moveStar();
            const interval = setInterval(() => { if (gameActive && starDiv) moveStar(); }, 800);
            gameDiv.addEventListener('remove', () => clearInterval(interval));
        }
        
        // Photo Upload
        document.getElementById('uploadPhotoBtn').addEventListener('click', () => {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.onchange = (e) => {
                const file = e.target.files[0];
                if (file) {
                    const url = URL.createObjectURL(file);
                    const img = document.createElement('img');
                    img.src = url;
                    img.style.width = '80px';
                    img.style.height = '80px';
                    img.style.borderRadius = '20px';
                    img.style.border = '3px solid gold';
                    img.style.objectFit = 'cover';
                    document.getElementById('photoPreview').appendChild(img);
                }
            };
            input.click();
        });
        
        // Music Upload
        document.getElementById('uploadMusicBtn').addEventListener('click', () => {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'audio/*';
            input.onchange = (e) => {
                const file = e.target.files[0];
                if (file) {
                    const url = URL.createObjectURL(file);
                    const audio = document.getElementById('bgMusic');
                    audio.src = url;
                    audio.play().catch(console.log);
                }
            };
            input.click();
        });
        
        // Animation Loop
        let time = 0;
        function animate() {
            requestAnimationFrame(animate);
            time += 0.016;
            
            // Animate character
            characterGroup.position.y = Math.sin(time * 1.8) * 0.008;
            characterGroup.rotation.z = Math.sin(time * 1.2) * 0.02;
            
            // Animate hearts
            hearts.forEach((heart, idx) => {
                heart.position.y += 0.003;
                if (heart.position.y > 2.3) heart.position.y = -0.3;
            });
            
            // Animate sparkles
            sparkles.rotation.y += 0.002;
            sparkles.rotation.x = Math.sin(time * 0.3) * 0.1;
            
            // Animate flame
            if (cutAmount < 1) {
                flame.scale.setScalar(0.8 + Math.sin(time * 20) * 0.2);
            }
            
            controls.update();
            renderer.render(scene, camera);
        }
        
        animate();
        
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>